{
  "1": {
    "full_name": "乾为天",
    "gua_ci": "元，亨，利，贞。",
    "name": "乾",
    "symbol": "乾上乾下乾：元，亨，利，贞。",
    "tuan": "大哉乾元，万物资始，乃统天。云行雨施，品物流形。大明始终，六位时成，时乘六龙以御天。乾道变化，各正性命，保合大和，乃利贞。首出庶物，万国咸宁。",
    "xiang": "天行健，君子以自强不息。  \n潜龙勿用，阳在下也。  \n见龙在田，德施普也。  \n终日乾乾，反复道也。  \n或跃在渊，进无咎也。  \n飞龙在天，大人造也。  \n亢龙有悔，盈不可久也。  \n用九，天德不可为首也。",
    "yao": {
      "三": {
        "text": "君子终日乾乾，夕惕若，厉无咎。",
        "xiang": ""
      },
      "上九": {
        "text": "亢龙有悔。",
        "xiang": ""
      },
      "二": {
        "text": "见龙在田，利见大人。",
        "xiang": ""
      },
      "五": {
        "text": "飞龙在天，利见大人。",
        "xiang": ""
      },
      "初九": {
        "text": "潜龙，勿用。",
        "xiang": ""
      },
      "四": {
        "text": "或跃在渊，无咎。",
        "xiang": ""
      }
    }
  },
  "2": {
    "full_name": "坤为地",
    "gua_ci": "元，亨，利牝马之贞。君子有攸往，先迷后得主，利西南得朋，东北丧朋。安贞，吉。",
    "name": "坤",
    "symbol": "坤上坤下坤：元，亨，利牝马之贞。君子有攸往，先迷后得主，利西南得朋，东北丧朋。安贞，吉。",
    "tuan": "至哉坤元，万物资生，乃顺承天。坤厚载物，德合无疆。含弘光大，品物咸亨。牝马地类，行地无疆，柔顺利贞。君子攸行，先迷失道，后顺得常。西南得朋，乃与类行；东北丧朋，乃终有庆。安贞之吉，应地无疆。",
    "xiang": "地势坤，君子以厚德载物。",
    "yao": {
      "三": {
        "text": "含章可贞。",
        "xiang": ""
      },
      "上六": {
        "text": "战龙于野，其血玄黄。",
        "xiang": ""
      },
      "二": {
        "text": "直，方，大，不习无不利。",
        "xiang": ""
      },
      "五": {
        "text": "黄裳，元吉。",
        "xiang": ""
      },
      "六": {
        "text": "利永贞。",
        "xiang": ""
      },
      "初六": {
        "text": "履霜，坚冰至。",
        "xiang": ""
      },
      "四": {
        "text": "括囊；无咎，无誉。",
        "xiang": ""
      }
    }
  },
  "3": {
    "full_name": "水雷屯",
    "gua_ci": "元，亨，利，贞，勿用，有攸往，利建侯。",
    "name": "屯",
    "symbol": "坎上震下屯：元，亨，利，贞，勿用，有攸往，利建侯。",
    "tuan": "屯，刚柔始交而难生，动乎险中，大亨贞。雷雨之动满盈，天造草昧，宜建侯而不宁。",
    "xiang": "云，雷，屯；君子以经纶。",
    "yao": {
      "三": {
        "text": "既鹿无虞，惟入于林中，君子几不如舍，往吝。",
        "xiang": ""
      },
      "上六": {
        "text": "乘马班如，泣血涟如。",
        "xiang": ""
      },
      "二": {
        "text": "屯如辶颤如，乘马班如。",
        "xiang": ""
      },
      "五": {
        "text": "屯其膏，小贞吉，大贞凶。",
        "xiang": ""
      },
      "初九": {
        "text": "磐桓；利居贞，利建侯。",
        "xiang": ""
      },
      "四": {
        "text": "乘马班如，求婚媾，无不利。",
        "xiang": ""
      }
    }
  },
  "4": {
    "full_name": "山水蒙",
    "gua_ci": "亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。",
    "name": "蒙",
    "symbol": "艮上坎下蒙：亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。",
    "tuan": "蒙，山下有险，险而止，蒙。蒙亨，以亨行时中也。匪我求童蒙，童蒙求我，志应也。初噬告，以刚中也。再三渎，渎则不告，渎蒙也。蒙以养正，圣功也。",
    "xiang": "山下出泉，蒙；君子以果行育德。",
    "yao": {
      "三": {
        "text": "勿用娶女；见金夫，不有躬，无攸利。",
        "xiang": ""
      },
      "上九": {
        "text": "击蒙；不利为寇，利御寇。",
        "xiang": ""
      },
      "二": {
        "text": "包蒙吉；纳妇吉；子克家。",
        "xiang": ""
      },
      "五": {
        "text": "童蒙，吉。",
        "xiang": ""
      },
      "初六": {
        "text": "发蒙，利用刑人，用说桎梏，以往吝。",
        "xiang": ""
      },
      "四": {
        "text": "困蒙，吝。",
        "xiang": ""
      }
    }
  },
  "5": {
    "full_name": "水天需",
    "gua_ci": "有孚，光亨，贞吉。利涉大川。",
    "name": "需",
    "symbol": "坎上乾下需：有孚，光亨，贞吉。利涉大川。",
    "tuan": "需，须也；险在前也。刚健而不陷，其义不困穷矣。需有孚，光亨，贞吉。位乎天位，以正中也。利涉大川，往有功也。",
    "xiang": "云上於天，需；君子以饮食宴乐。",
    "yao": {
      "三": {
        "text": "需于泥，致寇至。",
        "xiang": ""
      },
      "上六": {
        "text": "入于穴，有不速之客三人来，敬之终吉。",
        "xiang": ""
      },
      "二": {
        "text": "需于沙。",
        "xiang": ""
      },
      "五": {
        "text": "需于酒食，贞吉。",
        "xiang": ""
      },
      "初九": {
        "text": "需于郊。",
        "xiang": ""
      },
      "四": {
        "text": "需于血，出自穴。",
        "xiang": ""
      }
    }
  },
  "64": {
    "full_name": "火水未济",
    "gua_ci": "亨，小狐汔济，濡其尾，无攸利。",
    "name": "未济",
    "symbol": "离上坎下未济：亨，小狐汔济，濡其尾，无攸利。",
    "tuan": "未济，亨；柔得中也。小狐汔济，未出中也。濡其尾，无攸利；不续终也。虽不当位，刚柔应也。",
    "xiang": "火在水上，未济；君子以慎辨物居方。",
    "yao": {
      "三": {
        "text": "未济，征凶，利涉大川。",
        "xiang": ""
      },
      "上九": {
        "text": "有孚于饮酒，无咎，濡其首，有孚失是。",
        "xiang": ""
      },
      "二": {
        "text": "曳其轮，贞吉。",
        "xiang": ""
      },
      "五": {
        "text": "贞吉，无悔，君子之光，有孚，吉。",
        "xiang": ""
      },
      "初六": {
        "text": "濡其尾，吝。",
        "xiang": ""
      },
      "四": {
        "text": "贞吉，悔亡，震用伐鬼方，三年有赏于大国。",
        "xiang": ""
      }
    }
  }
}